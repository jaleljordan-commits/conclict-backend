{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "java -Dserver.port=$PORT -jar target/conflict-tracker-0.0.1-SNAPSHOT.jar --spring.profiles.active=production"
  },
  "environments": {
    "production": {
      "variables": {
        "SPRING_PROFILES_ACTIVE": "production",
        "PORT": "8080"
      }
    }
  }
}